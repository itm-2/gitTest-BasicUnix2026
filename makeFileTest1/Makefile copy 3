cc = gcc
CFLAGS = -Wall

.PHONY: all clean

app: main.o add.o # app 대신 all 써도 됨
	$(cc) $(CFLAGS) main.o add.o -o app

main.o: main.c add.h # main.c까지만 적어도 되지만, add.h도 적어주는 것이 좋음
# t1: add.h를 수정, t2: main.o는 main.c에만 의존적이므로 재컴파일을 하지 않음.
# 자동으로 생성해주는 dependency list 필요
	$(cc) $(CFLAGS) main.c -c

add.o: add.c add.h
	$(cc) $(CFLAGS) add.c -c

clean:
	rm -rf app *.o

helloTest: abc def
	echo $^
abc:
	@echo abc
# @ 빼면 echo abc도 출력되고, abc도 출력됨.
def:
	@echo def